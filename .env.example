DATABASE_URL=postgres://docpulse:docpulse@localhost:5432/docpulse?sslmode=disable
REDIS_URL=redis://localhost:6379

PORT=8080
BASE_URL=http://localhost:8080

OPENAI_API_KEY=sk-your-key-here

LLM_FAST_MODEL=gpt-4o-mini
LLM_STRONG_MODEL=gpt-4o
LLM_MAX_RETRIES=2
LLM_COMPLEXITY_THRESHOLD=10

WORKER_CONCURRENCY=4
WORKER_POLL_INTERVAL=2s
WORKER_MAX_JOB_DURATION=10m

STORAGE_LOCAL_DIR=/tmp/docpulse
